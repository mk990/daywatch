# Optional first-boot seed: registers an app named "default" with this token.
# Apps and tokens are managed from the panel's Apps page after that — you can
# leave this empty and create apps in the panel instead. While no app is
# registered at all, any token is accepted (fine for local dev only).
NIGHTWATCH_TOKEN=

# Panel login. Both must be set to enable authentication (JWT session
# cookie, 7 days). Leave both empty to run the panel without a login.
DAYWATCH_USERNAME=admin
DAYWATCH_PASSWORD=change-me

# Optional: explicit JWT signing secret. When empty a stable secret is
# derived from the credentials, so sessions survive restarts either way.
DW_JWT_SECRET=

# Postgres password used by the docker-compose stack.
POSTGRES_PASSWORD=daywatch

# Days to keep ingested records before pruning. 0 disables pruning.
DW_RETENTION_DAYS=14

# Host ports published by docker compose.
DW_INGEST_PORT=2407
DW_HTTP_PORT=8080

# Timezone used for chart labels and timestamps in the panel.
TZ=UTC
